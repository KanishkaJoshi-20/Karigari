# =============================================================
#  Karigari Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env to version control.
# =============================================================

NODE_ENV=development
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>

# JWT — use a long, random string (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Session secret — same rules as JWT_SECRET
SESSION_SECRET=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email — Nodemailer via Gmail
# Step 1: Enable 2-Factor Authentication on your Google Account
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Create an App Password for "Mail" → copy the 16-char password
# ⚠️  Use the App Password here, NOT your normal Gmail password
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
